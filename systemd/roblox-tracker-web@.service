[Unit]
Description=Roblox Tracker Web Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=%h
ExecStart=/usr/bin/python3 -m roblox_tracker serve --host 0.0.0.0 --port 5000
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.roblox_tracker
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
